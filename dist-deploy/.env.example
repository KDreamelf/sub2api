# =============================================================================
# Sub2API 部署环境配置
# =============================================================================
# 复制此文件为 .env 并修改:
#   cp .env.example .env
#   nano .env
# =============================================================================

# 监听地址与端口
BIND_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=release

# 运行模式: standard (完整SaaS) 或 simple (内部自用)
RUN_MODE=standard

# 时区
TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# PostgreSQL（固定密码，与已有数据卷一致，勿随意更改）
# -----------------------------------------------------------------------------
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=b77ea22603ed00eeed9bc41da9711408
POSTGRES_DB=sub2api

# -----------------------------------------------------------------------------
# Redis（固定密码，与已有数据卷一致，勿随意更改）
# -----------------------------------------------------------------------------
REDIS_PASSWORD=ec1ff75c5a2d98ebc8d96e95b41a7261
REDIS_DB=0

# -----------------------------------------------------------------------------
# 管理员账号（首次启动自动创建）
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@sub2api.local
# 留空则自动生成，会在首次启动日志中输出
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# JWT（重要：设置固定值避免重启后登录失效）
# 生成方式: openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRE_HOUR=24

# -----------------------------------------------------------------------------
# TOTP 双因素认证加密密钥（重要：设置固定值）
# 生成方式: openssl rand -hex 32
# -----------------------------------------------------------------------------
TOTP_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Gemini OAuth（可选）
# -----------------------------------------------------------------------------
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
GEMINI_OAUTH_SCOPES=

# Antigravity OAuth（可选）
ANTIGRAVITY_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# 更新代理（可选，国内服务器访问 GitHub 时使用）
# 示例: http://127.0.0.1:7890 或 socks5://127.0.0.1:1080
# -----------------------------------------------------------------------------
UPDATE_PROXY_URL=
